{
	"display_information": {
		"name": "My Assistant",
		"description": "Your personal AI assistant in Slack.",
		"background_color": "#1a1a2e"
	},
	"features": {
		"bot_user": {
			"display_name": "My Assistant",
			"always_online": false
		}
	},
	"oauth_config": {
		"scopes": {
			"bot": [
				"channels:history",
				"chat:write",
				"reactions:write",
				"reactions:read",
				"users:read"
			]
		}
	},
	"settings": {
		"event_subscriptions": {
			"request_url": "https://<region>-<project-id>.cloudfunctions.net/slackbot/events",
			"bot_events": ["message.channels"]
		},
		"interactivity": {
			"is_enabled": true,
			"request_url": "https://<region>-<project-id>.cloudfunctions.net/slackbot/events"
		},
		"org_deploy_enabled": false,
		"socket_mode_enabled": false,
		"token_rotation_enabled": false
	}
}
