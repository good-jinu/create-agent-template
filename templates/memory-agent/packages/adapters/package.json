			"import": "./dist/memory/index.chroma.mjs",
			"types": "./dist/memory/index.chroma.d.mts"
		},
		"./firestore": {
			"import": "./dist/memory/index.firestore.mjs",
			"types": "./dist/memory/index.firestore.d.mts"
		},
		"./lancedb": {
			"import": "./dist/memory/index.lancedb.mjs",
			"types": "./dist/memory/index.lancedb.d.mts"
		}
	},
	"scripts": {
		"build": "tsdown",
		"dev": "tsdown --watch"
	},
	"dependencies": {
		"@ai-sdk/google": "^3.0.63",
		"@google-cloud/firestore": "^7.11.0",
		"@lancedb/lancedb": "^0.17.0",
		"@my-ai-agent/core": "workspace:*",
		"@slack/bolt": "^4.7.0",
		"ai": "^6.0.159",
		"chromadb": "^3.4.3",
		"ollama-ai-provider-v2": "^3.5.0"
	},
	"devDependencies": {
		"tsdown": "^0.21.8",
		"typescript": "^6.0.2"
	}
