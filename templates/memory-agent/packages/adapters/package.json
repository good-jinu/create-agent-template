{
	"name": "@my-ai-agent/adapters",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"main": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"exports": {
		".": {
			"import": "./dist/index.mjs",
			"types": "./dist/index.d.mts"
		},
