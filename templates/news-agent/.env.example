# ─── Slack ────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-your-bot-token              # required for Slack API calls
SLACK_SIGNING_SECRET=your-slack-signing-secret   # required for Firebase Slack event verification
SLACK_APP_TOKEN=xapp-your-app-level-token        # local only, Socket Mode
SLACK_CONFIG_REFRESH_TOKEN=xoxe-1-your-refresh   # deploy only, recommended for automated rotation
SLACK_CONFIG_TOKEN=xoxe.xoxp-your-config-token   # deploy only, backup if no refresh token
NEWS_SUMMARY_CHANNEL_ID=C0123456789              # optional, daily news summary channel

# ─── Google AI (Gemini) ───────────────────────────────────────────
GOOGLE_GENERATIVE_AI_API_KEY=your-gemini-api-key  # required for Firebase functions

# ─── OpenAI ──────────────────────────────────────────────────────
OPENAI_API_KEY=your-openai-api-key                # required for Firebase functions

# ─── NewsAPI ─────────────────────────────────────────────────────
NEWS_API_KEY=your-newsapi-api-key                 # required for daily news summary

# ─── Optional ─────────────────────────────────────────────────────
# FIREBASE_REGION=us-central1
