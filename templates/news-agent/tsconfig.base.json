{
	"compilerOptions": {
		"module": "preserve",
		"moduleResolution": "bundler",
		"target": "es2022",
		"strict": true,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"paths": {
			"@my-assistant/core": [
				"./packages/core/src/index.ts"
			],
			"@my-assistant/adapters": [
				"./packages/adapters/src/index.ts"
			]
		}
	}
}