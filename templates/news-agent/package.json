{
	"name": "my-assistant",
	"private": true,
	"scripts": {
		"build": "pnpm -r build",
		"eval:workflows": "pnpm --filter @my-assistant/workflow-eval start",
		"typecheck": "tsc --noEmit",
		"deploy": "firebase deploy --only functions --config packages/functions/firebase.json",
		"deploy:firebase": "bash scripts/deploy-firebase.sh",
		"deploy:slack": "bash scripts/deploy-slack.sh",
		"deploy:slack:local": "bash scripts/deploy-slack.sh --local",
		"deploy:full": "bash scripts/deploy-firebase.sh && bash scripts/deploy-slack.sh",
		"local:run": "pnpm --filter @my-assistant/local-run start",
		"lint": "biome check packages/",
		"lint:fix": "biome check --fix packages/",
		"format": "biome format --write packages/"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.11",
		"tsdown": "^0.21.8",
		"typescript": "^6.0.3"
	}
}
