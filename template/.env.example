# ─── Slack ────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-your-local-dev-bot-token   # local dev app (packages/localRun)
SLACK_APP_TOKEN=xapp-your-app-level-token        # Socket Mode (packages/localRun)
SLACK_CHANNEL_ID=C01234567                       # channel to watch for messages
SLACK_CONFIG_TOKEN=xoxe.xoxp-your-config-token  # deploy script only

# ─── GitHub ───────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_your-github-token
GITHUB_OWNER=your-org-or-username

# ─── Google AI (Gemini) — packages/functions only ─────────────────
GOOGLE_GENERATIVE_AI_API_KEY=your-gemini-api-key

# ─── Optional ─────────────────────────────────────────────────────
# FIREBASE_REGION=us-central1
# MAX_INVESTIGATION_STEPS=5
